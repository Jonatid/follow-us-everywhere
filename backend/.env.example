# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (for local development)
# Option 1: Local PostgreSQL
DB_USER=YOUR_DB_USER
DB_PASSWORD=YOUR_DB_PASSWORD
DB_HOST=localhost
DB_PORT=5432
DB_NAME=YOUR_DB_NAME

# Option 2: Render.com or other cloud services
# Uncomment and set this instead of the individual DB variables above
# DATABASE_URL=postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_DB_HOST:YOUR_DB_PORT/YOUR_DB_NAME?sslmode=require

# JWT Configuration
JWT_SECRET=YOUR_JWT_SECRET
JWT_EXPIRE=7d

# Frontend base URL used by business password reset links
FRONTEND_URL=YOUR_FRONTEND_URL

# Optional customer frontend URL used by customer password reset links
# Defaults to FRONTEND_URL when not set.
CUSTOMER_FRONTEND_URL=YOUR_CUSTOMER_FRONTEND_URL

# Resend email provider settings for password reset emails
RESEND_API_KEY=YOUR_RESEND_API_KEY
RESEND_FROM=YOUR_RESEND_FROM_EMAIL

# CORS Configuration
ALLOWED_ORIGINS=https://fuse101.com,https://www.fuse101.com,https://admin.fuse101.com
# In Render, set the same ALLOWED_ORIGINS value in the service environment variables.

# Optional: Enable detailed logging
DEBUG=false

# Landing page URL used for QR redirects
LANDING_PAGE_URL=YOUR_LANDING_PAGE_URL

# Login brute-force protection
# Optional Redis URL for external/shared stores when enabled by deployment policy
REDIS_URL=redis://127.0.0.1:6379
LOCKOUT_MINUTES=15
MAX_FAILED_ATTEMPTS=5
WARN_AT_ATTEMPTS=4
RATE_LIMIT_WINDOW_SECONDS=600
RATE_LIMIT_MAX=20
