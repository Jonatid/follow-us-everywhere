#!/usr/bin/env bash
set -euo pipefail

staged_files=$(git diff --cached --name-only --diff-filter=ACM)

if [[ -z "${staged_files}" ]]; then
  exit 0
fi

# Optional: run gitleaks when available.
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --config .gitleaks.toml --redact --verbose
fi

# Never allow real .env files to be committed.
while IFS= read -r file; do
  [[ -z "$file" ]] && continue
  if [[ "$file" =~ (^|/)\.env($|\.) ]] && [[ "$file" != *.env.example ]]; then
    echo "❌ Commit blocked: '$file' looks like a real .env file."
    echo "   Keep real secrets only in local untracked .env files or Render environment variables."
    exit 1
  fi
done <<< "$staged_files"

# Lightweight fallback check for likely hardcoded secrets in added lines.
# Prefer ripgrep when available; otherwise use a bash-only parser so hooks
# remain functional on Windows environments where `rg` may be missing in PATH.
if command -v rg >/dev/null 2>&1; then
  added_lines=$(git diff --cached --unified=0 --no-color | rg '^[+]' | rg -v '^\+\+\+' || true)
else
  added_lines=""
  while IFS= read -r line; do
    [[ "${line}" == +++* ]] && continue
    if [[ "${line}" == +* ]]; then
      added_lines+="${line}"
      added_lines+=$'\n'
    fi
  done < <(git diff --cached --unified=0 --no-color)
fi

if [[ -z "$added_lines" ]]; then
  exit 0
fi

lower_added=$(printf '%s' "$added_lines" | tr '[:upper:]' '[:lower:]')

if [[ "$lower_added" =~ (api[_-]?key|secret|token|password|passwd|private[_-]?key)[[:space:]]*[:=][[:space:]]*[a-z0-9_-]{8,} ]]; then
  if [[ ! "$lower_added" =~ (your_|example|changeme|localhost|127\.0\.0\.1) ]]; then
    echo "❌ Commit blocked: possible secret detected in staged changes."
    echo "   Use placeholders in committed files and store real values in Render environment variables."
    exit 1
  fi
fi

exit 0
